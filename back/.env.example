# Backend Environment Variables

# MongoDB Connection
MONGO_URI=your_mongodb_connection_string_here

# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:5173

# JWT Secret Key
SECRET_KEY=your_secret_key_here

# Cibpay Configuration
CIBPAY_USER=your_cibpay_username_here
CIBPAY_PASS=your_cibpay_password_here
CIBPAY_API_URL=https://api-preprod.cibpay.co   # switch to https://api.cibpay.co for production
CIBPAY_PFX_PATH=./cert/api-cibpay.p12        # optional, path to your PFX file if used
CIBPAY_PFX_PASSPHRASE=your_cibpay_pfx_passphrase_here
CIBPAY_WEBHOOK_USER=your_webhook_username_here
CIBPAY_WEBHOOK_PASS=your_webhook_password_here

# MyGov API Configuration
MYGOV_API_URL=https://insure.az/api
MYGOV_USERNAME=ASANPAY
MYGOV_PASSWORD=your_mygov_password_here
