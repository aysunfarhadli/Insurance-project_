# Frontend Environment Variables
# Vite requires VITE_ prefix for environment variables to be exposed to the client

# Backend API URL
# VITE_API_BASE_URL=https://insurance-project-e1xh.onrender.com

# For local development, uncomment the line below:
VITE_API_BASE_URL=http://localhost:5000

# Set to false to allow testing without login
VITE_ENABLE_LOGIN=false
